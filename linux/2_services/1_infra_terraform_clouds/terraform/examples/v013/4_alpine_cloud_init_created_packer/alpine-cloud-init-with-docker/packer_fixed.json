{
    "builders": [
      {
        "accelerator": "kvm",
        "boot_command": [
          "root<enter><wait>",
          "ip link set eth0 up \u0026\u0026 udhcpc -i eth0 \u0026\u0026<enter>",
          "wget http://{{ .HTTPIP }}:{{ .HTTPPort }}/setup.sh \u0026\u0026<enter>",
          "chmod +x setup.sh \u0026\u0026 ./setup.sh<enter>"
        ],
        "boot_wait": "10s",
        "disk_size": "8000M",
        "format": "qcow2",
        "headless": "false",
        "http_directory": "httpdir",
        "iso_checksum": "sha256:fe694a34c0e2d30b9e5dea7e2c1a3892c1f14cb474b69cc5c557a52970071da5",
        "iso_url": "http://dl-cdn.alpinelinux.org/alpine/latest-stable/releases/x86_64/alpine-virt-3.12.0-x86_64.iso",
        "output_directory": "images",
        "qemuargs": [
          [
            "-device",
            "virtio-net,netdev=user.0"
          ],
          [
            "-object",
            "rng-random,id=objrng0,filename=/dev/urandom"
          ],
          [
            "-device",
            "virtio-rng-pci,rng=objrng0,id=rng0,bus=pci.0,addr=0x10"
          ]
        ],
        "shutdown_command": "/sbin/poweroff",
        "ssh_password": "root",
        "ssh_timeout": "1h",
        "ssh_username": "root",
        "type": "qemu",
        "vm_name": "alpine-docker.qcow2"
      }
    ],
    "provisioners": [
      {
        "script": "scripts/install-docker.sh",
        "type": "shell"
      }
    ]
  }
